# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Where the frontend is served (used to build buyer/vendor links dropped in chat)
APP_BASE_URL=http://localhost:5173
# Public URL of THIS backend (Monnify posts webhooks here). Use an ngrok URL in a live demo.
PUBLIC_BASE_URL=http://localhost:4000

# ── Monnify (sandbox) ────────────────────────────────────
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REQUIRED for real reserved accounts. Monnify Dashboard → Settings → API Keys & Webhooks → "Contract Code".
# Leave blank to run in SIMULATION mode (accounts + payments are simulated so the app still demos end-to-end).
MONNIFY_CONTRACT_CODE=
# Your Monnify wallet account number — the source account for disbursements/releases.
MONNIFY_WALLET_ACCOUNT=9976453872
# Sandbox 2FA OTP used to authorize disbursements when your wallet has Transfer 2FA enabled.
MONNIFY_DISBURSEMENT_OTP=123456

# ── AI (Groq, OpenAI-compatible) ─────────────────────────
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# Smartest free vision-capable model on this Groq account.
LLM_MODEL=qwen/qwen3.6-27b

# ── Escrow policy ────────────────────────────────────────
# Confirmation window before funds auto-release to the vendor on buyer silence.
DELIVERY_WINDOW_HOURS=24
# For demos, override the window with a short value in seconds (takes priority when > 0).
DELIVERY_WINDOW_SECONDS=90

# ── Ops ──────────────────────────────────────────────────
# Protects the internal human-review console API.
ADMIN_TOKEN=change-me-admin-token
# Enables the /simulate-payment helper + faster demo behaviour.
DEMO_MODE=true
